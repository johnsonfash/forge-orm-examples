{
  "name": "forge-orm examples",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:20-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "forwardPorts": [3000, 5173, 5432, 1433, 27017],
  "portsAttributes": {
    "3000":  { "label": "Hono / Next API" },
    "5173": { "label": "Vite dev server" },
    "5432": { "label": "Postgres" },
    "1433": { "label": "SQL Server" },
    "27017":{ "label": "MongoDB" }
  },
  "postCreateCommand": "docker compose -f .devcontainer/docker-compose.yml up -d",
  "remoteEnv": {
    "DATABASE_URL_PG":    "postgres://postgres:postgres@localhost:5432/forge",
    "DATABASE_URL_MSSQL": "mssql://sa:Forge_Strong_Pass1!@localhost:1433/forge",
    "DATABASE_URL_MONGO": "mongodb://localhost:27017/forge"
  },
  "customizations": {
    "vscode": {
      "extensions": ["dbaeumer.vscode-eslint", "esbenp.prettier-vscode"]
    }
  }
}
